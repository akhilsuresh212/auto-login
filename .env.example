# URL of the GreytHR portal
GREYTHR_URL="https://chisquarelabs.greythr.com/"

# Username for GreytHR
GREYTHR_USERNAME="your_username_here"

# Password for GreytHR
# Run `npx dotenvx encrypt` to encrypt this file after filling it in.
GREYTHR_PASSWORD="your_password_here"

# Cron Schedule for Login (Default: 9:00 AM Mon-Fri)
LOGIN_TIME="0 8 * * 1-5"

# Cron Schedule for Logout (Default: 6:45 PM Mon-Fri)
LOGOUT_TIME="45 18 * * 1-5"

# Headless mode for browser (true for Docker/CI, false for local debugging)
HEADLESS=true

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=